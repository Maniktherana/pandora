{
  "name": "pandora",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prepare": "effect-language-service patch",
    "desktop:dev": "bun run --filter @pandora/desktop tauri:dev",
    "desktop:build": "bun run --filter @pandora/desktop tauri:build"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "effect-solutions": "^0.5.2",
    "turbo": "^2.5.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
