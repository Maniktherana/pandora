{
  "name": "pandora",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "desktop:dev": "bun run --filter @pandora/desktop tauri:dev",
    "desktop:build": "bun run --filter @pandora/desktop tauri:build",
    "daemon:dev": "bun --cwd apps/daemon run dev"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "node-pty"
  ]
}
